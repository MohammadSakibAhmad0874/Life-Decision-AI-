# ─── Life Decision AI — Environment Variables ─────────────────────────────────
# Copy this file to `.env` and fill in your real values.
# NEVER commit .env to version control.

# Razorpay (TEST mode) — get from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX

# JWT secret — use a long random string (e.g. openssl rand -hex 32)
SECRET_KEY=change_me_to_a_long_random_secret_string_for_production

# Database URL — SQLite absolute path (auto-set in models.py)
# DATABASE_URL=sqlite:///C:/Users/YourName/Desktop/AI Soft Computing/life-decision-ai/life_decision_ai.db
